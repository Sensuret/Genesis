# Supabase — from https://supabase.com/dashboard/project/_/settings/api
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Optional: embedded Notion page URL for the Notebook tab
NEXT_PUBLIC_NOTION_EMBED_URL=https://www.notion.so/your-public-page

# Optional: site URL used for OAuth redirects
NEXT_PUBLIC_SITE_URL=http://localhost:3000
